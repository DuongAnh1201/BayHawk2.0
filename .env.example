# ============================================================================
# BayHawk 2.0 — Wildfire Watch MVP
# Copy this file to .env and fill in your values:  cp .env.example .env
# ============================================================================

# ── Gateway / Auth ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./bayhawk.db

# ── AI Pipeline: Vision-Language Model ─────────────────────────────────────
# OpenAI API key for reasoning, classification, and suggestion agents
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── Camera Agent: ALERTCalifornia ──────────────────────────────────────────
# UC San Diego wildfire camera network (~1,200 HD cameras across California)
# Requires partner application (may take days): https://alertcalifornia.org/
# Leave blank if not approved — the frontend uses Windy Webcams for live feed
ALERTCA_API_KEY=

# ── Satellite Agent: NASA FIRMS (FREE — instant registration) ─────────────
# Near real-time thermal hotspot data (VIIRS SNPP)
# 1. Go to: https://firms.modaps.eosdis.nasa.gov/api/area/
# 2. Click "Get Map Key" → sign up with email → key is emailed instantly
NASA_FIRMS_MAP_KEY=

# ── Weather Agent: OpenWeatherMap (FREE — instant registration) ────────────
# Current weather data (wind speed, humidity, direction) for spread-risk calc
# 1. Go to: https://home.openweathermap.org/users/sign_up
# 2. Sign up → go to API keys tab → copy your default key
# Free tier: 1,000 calls/day (more than enough)
OPENWEATHERMAP_API_KEY=

# ── YOLOv8 (Camera Agent inference) ───────────────────────────────────────
YOLO_MODEL_PATH=yolov8n.pt
YOLO_INFERENCE_IMGSZ=640

# ── Collection HTTP settings ──────────────────────────────────────────────
COLLECTION_HTTP_MAX_ATTEMPTS=3
COLLECTION_CACHE_TTL_SEC=0

# ── Satellite Agent tuning ─────────────────────────────────────────────────
FIRMS_BBOX_HALF_DEG=0.1
FIRMS_FRP_NORMALIZE=100.0

# ── Fusion Agent tuning ───────────────────────────────────────────────────
FUSION_THRESHOLD=0.40
FUSION_CAMERA_WEIGHT=0.6

# ── Output Agent ───────────────────────────────────────────────────────────
DASHBOARD_WEBHOOK_URL=

# ── Mock Mode ──────────────────────────────────────────────────────────────
# Set to "true" to bypass all external APIs and LLM calls (local dev / tests)
IS_MOCK=false

# ── Twilio SMS (Emergency Alerts) ────────────────────────────────────────
# Sign up at: https://www.twilio.com/try-twilio
# Get SID + Auth Token from console dashboard; buy a phone number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Comma-separated phone numbers per recipient group (E.164 format, e.g. +15551234567)
SMS_RECIPIENTS_FIREFIGHTERS=
SMS_RECIPIENTS_CONTROL_CENTER=
SMS_RECIPIENTS_AREA_RESIDENTS=

# ── Frontend ───────────────────────────────────────────────────────────────
# Backend API URL for the frontend to connect to
VITE_API_BASE_URL=http://localhost:8000

# Windy Webcams API — live camera feeds on the dashboard
# Get free key at: https://api.windy.com/keys
VITE_WINDY_API_KEY=
